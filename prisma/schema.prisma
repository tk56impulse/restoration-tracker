generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Property {
  id        String   @id @default(cuid())
  name      String
  address   String
  rooms     Room[]
  createdAt DateTime @default(now())
}

model Room {
  id           String        @id @default(cuid())
  propertyId   String
  property     Property      @relation(fields: [propertyId], references: [id])
  number       String
  layout       String
  restorations Restoration[]
}

model Restoration {
  id                 String             @id @default(cuid())
  roomId             String
  room               Room               @relation(fields: [roomId], references: [id])
  status             String             @default("LEAVED") // enumからStringに変更
  leaveDate          DateTime
  totalAmount        Int                @default(0)
  tenantShare        Int                @default(0)
  ownerShare         Int                @default(0)
  items              ConstructionItem[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

model ConstructionItem {
  id            String      @id @default(cuid())
  restorationId String
  restoration   Restoration @relation(fields: [restorationId], references: [id])
  name          String
  unitPrice     Int
  quantity      Float
  isTenantShare Boolean     @default(false)
}

